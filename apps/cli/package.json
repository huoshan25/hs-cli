{
  "name": "@huo-shan/cli",
  "version": "0.2.0",
  "private": false,
  "description": "一个持续进化的 CLI 工具集",
  "main": "dist/index.js",
  "bin": {
    "hs-cli": "bin/hs-cli.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('fs-extra').removeSync('dist')\"",
    "build": "npm run clean && tsc",
    "build:openspec-web": "pnpm --filter @huo-shan/openspec-web build",
    "copy-openspec-web": "node -e \"require('fs-extra').copySync('../openspec-web/build/client', 'dist/openspec-web')\"",
    "copy-templates": "node -e \"require('fs-extra').copySync('src/commands/create/templates', 'dist/commands/create/templates')\"",
    "prepare-release-assets": "npm run build && npm run copy-templates && npm run build:openspec-web && npm run copy-openspec-web",
    "prepack": "npm run prepare-release-assets",
    "prepublishOnly": "npm run prepare-release-assets",
    "start": "node bin/hs-cli.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "cli:create": "node bin/hs-cli.js create",
    "cli:generate": "node bin/hs-cli.js generate",
    "cli:init": "node bin/hs-cli.js init"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "chalk": "^4.1.2",
    "cli-progress": "3.12.0",
    "commander": "^10.0.0",
    "fs-extra": "^10.1.0",
    "inquirer": "^8.2.5",
    "ora": "5.4.1",
    "typescript": "^4.9.5"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^9.0.13",
    "@types/inquirer": "^8.2.5",
    "@types/node": "^18.15.0",
    "ts-node": "^10.9.1",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "cli",
    "scaffold",
    "generator",
    "create",
    "vue",
    "nuxt",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/huoshan25/hs-cli"
  },
  "publishConfig": {
    "access": "public"
  }
}
